# MongoDB (via shared infrastructure — ports published to localhost)
# Note: directConnection=true and replicaSet required for single-node replica set
MONGODB_URI=mongodb://localhost:27017/?directConnection=true&replicaSet=rs0
MONGODB_DATABASE=aria

# LLM - Local (via shared infrastructure)
LLAMACPP_URL=http://localhost:8080/v1
LLAMACPP_API_KEY=

# LLM - Cloud (optional - for fallback)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Embeddings (via shared infrastructure)
EMBEDDING_URL=http://localhost:8001/v1
EMBEDDING_MODEL=voyageai/voyage-4-nano
EMBEDDING_DIMENSION=1024
VOYAGE_API_KEY=

# Voice Services (optional — Docker services publish ports to localhost)
TTS_URL=http://localhost:8002/v1
STT_URL=http://localhost:8003/v1

# Signal (optional)
SIGNAL_ENABLED=false
SIGNAL_REST_URL=http://localhost:8088
SIGNAL_ACCOUNT=
SIGNAL_DM_POLICY=allowlist

# Search (optional)
BRAVE_SEARCH_API_KEY=

# Deep Think — delegate reasoning to Claude Opus via CLI (optional)
# When enabled, the orchestrator model delegates thinking to Claude Opus
# via the Claude Code CLI, using subscription tokens instead of API tokens.
DEEP_THINK_ENABLED=true
DEEP_THINK_MODEL=
DEEP_THINK_TIMEOUT_SECONDS=180

# Background Processes (optional — requires Claude Code CLI)
USE_CLAUDE_RUNNER=true
CLAUDE_CODE_BINARY=claude

# API
API_HOST=0.0.0.0
API_PORT=8000
API_AUTH_ENABLED=true
API_KEY=aria-local-admin-key
DEBUG=false

# Security (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=
